  "active": false,
  "settings": { "executionOrder": "v1" },
  "meta": { "notes": "Handles inbound SMS from Twilio. Checks for STOP/UNSUBSCRIBE first (TCPA compliance), logs inbound, fetches conversation history, generates AI reply via Claude, sends reply, updates lead stage. Set this webhook URL in Twilio console under 'A message comes in'." }
