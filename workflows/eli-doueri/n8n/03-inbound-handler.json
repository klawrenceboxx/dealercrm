{
  "name": "[03] Inbound SMS Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "inbound-sms",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Twilio Inbound Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "jsCode": "// Twilio sends form-encoded data. Extract From (phone) and Body (message).\nconst input = $input.first().json;\nconst phone = input.From || input.from || '';\nconst body = (input.Body || input.body || '').trim();\n\nreturn [{ json: { phone, body } }];"
      },
      "id": "parse-twilio",
      "name": "Parse Twilio Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/leads",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "phone", "value": "=eq.{{ $json.phone }}" },
            { "name": "select", "value": "*" },
            { "name": "limit", "value": "1" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" }
          ]
        },
        "options": {}
      },
      "id": "find-lead",
      "name": "Find Lead by Phone",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "jsCode": "const leadResult = $input.first().json;\nconst leads = Array.isArray(leadResult) ? leadResult : [leadResult];\nconst lead = leads[0];\nconst inboundBody = $('Parse Twilio Payload').first().json.body;\nconst phone = $('Parse Twilio Payload').first().json.phone;\n\nif (!lead || !lead.id) {\n  return [{ json: { _action: 'unknown_phone', phone, body: inboundBody } }];\n}\n\n// OPT-OUT CHECK (TCPA) -- must happen FIRST\nconst OPT_OUT_KEYWORDS = ['stop', 'unsubscribe', 'quit', 'cancel'];\nconst isOptOut = OPT_OUT_KEYWORDS.includes(inboundBody.toLowerCase().trim());\n\nif (isOptOut) {\n  return [{ json: { ...lead, _action: 'opt_out', inbound_body: inboundBody } }];\n}\n\n// If lead is already hot, log inbound but don't auto-reply (salesperson owns it)\nif (lead.stage === 'hot' && lead.salesperson_alerted === true) {\n  return [{ json: { ...lead, _action: 'autopilot_off', inbound_body: inboundBody } }];\n}\n\n// Normal processing -- AI auto-replies\nreturn [{ json: { ...lead, _action: 'process', inbound_body: inboundBody } }];"
      },
      "id": "evaluate-lead",
      "name": "Evaluate Lead State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "outputIndex": 0, "conditions": { "conditions": [{ "leftValue": "={{ $json._action }}", "rightValue": "opt_out", "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputIndex": 1, "conditions": { "conditions": [{ "leftValue": "={{ $json._action }}", "rightValue": "autopilot_off", "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputIndex": 2, "conditions": { "conditions": [{ "leftValue": "={{ $json._action }}", "rightValue": "process", "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputIndex": 3, "conditions": { "conditions": [{ "leftValue": "={{ $json._action }}", "rightValue": "unknown_phone", "operator": { "type": "string", "operation": "equals" } }] } }
          ]
        }
      },
