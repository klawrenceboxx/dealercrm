    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "hot-check",
              "leftValue": "={{ $('Parse Inbound Response').first().json.is_hot }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            },
            {
              "id": "not-alerted",
              "leftValue": "={{ $('Parse Inbound Response').first().json.salesperson_alerted }}",
