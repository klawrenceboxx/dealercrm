      },
      "id": "fetch-last-messages",
      "name": "Fetch Last 3 Messages",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 480]
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Evaluate Lead State').first().json;\nconst messagesRaw = $input.first().json;\nconst messages = Array.isArray(messagesRaw) ? messagesRaw : [messagesRaw];\n\nconst lastMessages = messages\n  .reverse()\n  .map(m => `${m.direction === 'inbound' ? 'CUSTOMER' : 'AI'}: ${m.body}`)\n  .join('\\n');\n\nreturn [{ json: {\n  lead_id: lead.id,\n  trigger_type: 'inbound_reply',\n  _last_messages: lastMessages,\n  _last_reply: lead.inbound_body\n}}];"
      },
      "id": "prep-sms-engine-call",
      "name": "Prep SMS Engine Call",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 480]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/inventory",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "status", "value": "eq.available" },
            { "name": "select", "value": "vehicle,year,make,model,trim,color,mileage,price" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" }
          ]
        },
        "options": {}
      },
      "id": "fetch-inventory-inbound",
      "name": "Fetch Inventory",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2220, 480]
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Evaluate Lead State').first().json;\nconst prepData = $('Prep SMS Engine Call').first().json;\nconst inventoryRaw = $input.first().json;\nconst inventory = Array.isArray(inventoryRaw) ? inventoryRaw : [inventoryRaw];\n\nconst TRIGGER_INSTRUCTIONS = {\n  inbound_reply: 'The lead just replied. Respond naturally and directly to what they said. Classify intent based on their message.'\n};\n\nconst inventoryList = inventory\n  .filter(v => v.vehicle)\n  .map(v => `${v.vehicle} -- ${v.color || 'N/A'} -- ${v.mileage ? v.mileage.toLocaleString() + ' km' : 'New'} -- $${v.price ? v.price.toLocaleString() : 'Call'}`)\n  .join('\\n');\n\nconst systemPrompt = `You are an AI assistant for ${$env.DEALERSHIP_NAME} in ${$env.DEALERSHIP_CITY}.\nSales contact: ${$env.SALESPERSON_NAME}, ${$env.SALESPERSON_PHONE}\nHours: ${$env.DEALERSHIP_HOURS}\n\nCURRENT AVAILABLE INVENTORY:\n${inventoryList || '(No inventory loaded)'}\n\nRULES:\n- SMS under 160 characters unless the content truly requires more\n- Professional but warm -- not pushy, not robotic\n- Never use em dashes\n- No filler phrases\n- Always include a clear next step or question\n- Never lie about inventory availability\n\nOUTPUT FORMAT: JSON only\n{ \"sms_text\": \"...\", \"intent_score\": \"hot|warm|cold\", \"intent_reasoning\": \"...\" }\n\nINTENT DEFINITIONS:\nhot: asking for price/availability, wants test drive, ready to buy soon\nwarm: engaged and asking questions, comparing options\ncold: no reply yet, vague interest`;\n\nconst userMessage = `LEAD CONTEXT:\nName: ${lead.first_name} ${lead.last_name || ''}\nSource: ${lead.source}\nVehicle interest: ${lead.vehicle_interest || '(not specified)'}\nTrigger: inbound_reply\nLast 3 messages:\\n${prepData._last_messages || '(none)'}\nLast lead reply: ${prepData._last_reply}\n\nTRIGGER INSTRUCTIONS: ${TRIGGER_INSTRUCTIONS.inbound_reply}`;\n\nreturn [{ json: { lead, systemPrompt, userMessage } }];"
      },
      "id": "build-inbound-prompt",
      "name": "Build Inbound Claude Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 256,\n  \"system\": {{ JSON.stringify($json.systemPrompt) }},\n  \"messages\": [{\"role\": \"user\", \"content\": {{ JSON.stringify($json.userMessage) }} }]\n}",
        "options": {}
      },
      "id": "claude-inbound",
      "name": "Claude API (Inbound)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2660, 480]
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Evaluate Lead State').first().json;\nconst claudeResponse = $input.first().json;\n\nlet parsed;\ntry {\n  parsed = JSON.parse(claudeResponse.content[0].text.trim());\n} catch (e) {\n  parsed = {\n    sms_text: `Thanks for reaching out! ${$env.SALESPERSON_NAME} will get back to you shortly.`,\n    intent_score: 'warm',\n    intent_reasoning: 'Fallback: Claude returned invalid JSON on inbound'\n  };\n}\n\n// Determine new stage based on intent\nlet newStage = lead.stage;\nlet clearFollowUp = false;\nlet newFollowUp = null;\n\nif (parsed.intent_score === 'hot') {\n  newStage = 'hot';\n  clearFollowUp = true;\n} else if (parsed.intent_score === 'warm') {\n  newStage = 'warm';\n  clearFollowUp = true; // Pause sequence, rep should monitor\n} else {\n  // Cold reply still upgrades to warm (they replied)\n  newStage = 'warm';\n  newFollowUp = new Date(Date.now() + 3 * 86400000).toISOString();\n}\n\nreturn [{ json: {\n  lead_id: lead.id,\n  phone: lead.phone,\n  sms_text: parsed.sms_text,\n  intent_score: parsed.intent_score,\n  new_stage: newStage,\n  next_follow_up: clearFollowUp ? null : newFollowUp,\n  is_hot: parsed.intent_score === 'hot',\n  salesperson_alerted: lead.salesperson_alerted,\n  demo_mode: lead.demo_mode\n}}];"
      },
      "id": "parse-inbound-claude",
      "name": "Parse Inbound Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2880, 480]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
