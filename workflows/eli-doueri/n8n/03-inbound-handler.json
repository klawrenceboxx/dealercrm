    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/sms_log",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "lead_id", "value": "=eq.{{ $('Evaluate Lead State').first().json.id }}" },
            { "name": "select", "value": "direction,body,sent_at" },
            { "name": "order", "value": "sent_at.desc" },
            { "name": "limit", "value": "3" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" }
          ]
        },
