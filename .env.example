# Copy this to .env and fill in values.
# NEVER commit .env to git.

# Supabase (get from supabase.com → project → Settings → API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# n8n webhooks (get from n8n after creating workflows)
N8N_WEBHOOK_INTAKE=
N8N_WEBHOOK_SMS_ENGINE=
N8N_WEBHOOK_HOT_LEAD=
N8N_WEBHOOK_RESEND_TRACKING=
N8N_WEBHOOK_INBOUND=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Claude API (already configured in agent_1 — copy over)
ANTHROPIC_API_KEY=

# Supabase service role (for n8n to bypass RLS — keep this server-side only, NOT in VITE_ prefix)
SUPABASE_SERVICE_ROLE_KEY=

# n8n environment variables (set in n8n → Settings → Variables, NOT in .env)
# Listed here for reference only
# SUPABASE_URL=           (same as VITE_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY=
# ANTHROPIC_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# SALESPERSON_PHONE=      (Sleiman provides — gets hot lead SMS alerts)
# SALESPERSON_EMAIL=      (Sleiman provides — gets hot lead email alerts)
# SALESPERSON_NAME=       (e.g. "Alex")
# DEALERSHIP_NAME=        (e.g. "Eli Doueri Auto")
# DEALERSHIP_HOURS=       (e.g. "Mon-Sat 9am-6pm ET")
# DEALERSHIP_CITY=        (e.g. "Montreal, QC")
# APP_URL=                (Vercel deploy URL — used in hot lead email deep link)
# Configure Resend webhooks:
#   Event types: email.opened, email.clicked
#   Endpoint: your active n8n URL for workflow [07] Resend Email Tracking

# Frontend n8n base URLs
VITE_N8N_WEBHOOK_BASE_URL=
VITE_N8N_BASE_URL=
